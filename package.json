{
  "name": "dynamic-mui",
  "version": "2.0.14",
  "author": "Dinakaran S",
  "user": "dinakarans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DinakaranS/-dynamic-mui.git"
  },
  "homepage": "https://github.com/DinakaranS/-dynamic-mui",
  "bugs": {
    "url": "https://github.com/DinakaranS/-dynamic-mui/issues"
  },
  "main": "./dist/dynamic-mui.cjs.js",
  "module": "./dist/dynamic-mui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dynamic-mui.es.js",
      "require": "./dist/dynamic-mui.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "@mui/x-charts": "^6.0.0 || ^7.0.0",
    "@mui/x-data-grid": "^6.0.0 || ^7.0.0",
    "@mui/x-date-pickers": "^6.0.0 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/credential-providers": "^3.996.0",
    "@dnd-kit/core": "^6.3.1",
    "dayjs": "^1.11.19",
    "lodash": "^4.17.23",
    "numeral": "^2.0.6",
    "react-number-format": "^5.4.4",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "uuid": "^13.0.0",
    "validator": "^13.15.26"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:playground": "vite build -c vite.playground.config.ts",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "prepublishOnly": "yarn run build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^10.0.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-charts": "^8.27.0",
    "@mui/x-data-grid": "^8.27.1",
    "@mui/x-date-pickers": "^8.27.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/numeral": "^2.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
